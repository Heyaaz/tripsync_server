# Spring port uses the existing Nest env names where possible.
# You can source ../tmti_server/.env for local development.

SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tripsync
SPRING_DATASOURCE_USERNAME=tripsync
SPRING_DATASOURCE_PASSWORD=tripsync

JWT_SECRET=replace-with-existing-tmti-server-value
FRONTEND_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:8080/api

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:8080/api/auth/kakao/callback

TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
TOUR_API_SERVICE_KEY=
TOUR_API_MOBILE_OS=ETC
TOUR_API_MOBILE_APP=TripSync
TOUR_API_RESPONSE_TYPE=json

